# Copy this to .env.local for local development.
# On Vercel itself, most of these are added AUTOMATICALLY when you connect
# the integrations described in README.md — you usually only type in
# JWT_SECRET, ADMIN_USERNAME, and ADMIN_PASSWORD yourself.

# Random secret used to sign login sessions. Generate one with:
#   openssl rand -base64 32
JWT_SECRET=

# Default admin account, created automatically on first login attempt.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Added automatically when you create a Blob store on Vercel (Storage tab).
BLOB_READ_WRITE_TOKEN=

# Added automatically when you connect an Upstash Redis integration
# from the Vercel Marketplace.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
